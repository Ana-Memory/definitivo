	<parameter name="CANTIDAD" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[SELECT id,
	nombre,
	descripcion,
	tipo,
	precio,
	unidades
FROM veterinaria.producto
WHERE 
	 veterinaria.producto.unidades > $P{CANTIDAD}]]>
	</queryString>
