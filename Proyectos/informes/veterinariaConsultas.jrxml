	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="MySQL World"/>
	<parameter name="FECHA" class="java.sql.Date"/>
	<queryString language="SQL">
		<![CDATA[SELECT veterinaria.reserva.id_consulta,
	veterinaria.reserva.fecha,
	veterinaria.reserva.hora,
	veterinaria.consulta.tipo,
	veterinaria.consulta.precio,
	veterinaria.consulta.id_dueno,
	veterinaria.consulta.id_mascota
FROM veterinaria.reserva,
	veterinaria.consulta
WHERE 
	 veterinaria.consulta.id = veterinaria.reserva.id_consulta 
	 AND veterinaria.reserva.fecha = $P{FECHA}]]>
	</queryString>
